{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vitorpouza-dev",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-15",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "vitorpouza.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page",
    "run_worker_first": ["/google0752999b923df8aa.html"]
  }
}
