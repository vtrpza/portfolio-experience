{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vitorpouza-dev",
  "compatibility_date": "2026-07-15",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "vitorpouza.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
